# === DATABASE ===
POSTGRES_DB=cia_db
POSTGRES_USER=cia_user
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://cia_user:change_me_strong_password@localhost:5432/cia_db

# === REDIS / CELERY ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# === LLM PROVIDERS ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === SCRAPEOPS ===
SCRAPEOPS_API_KEY=your_scrapeops_api_key_here
SCRAPEOPS_URL=https://proxy.scrapeops.io/v1/

# === EXTERNAL APIs ===
SERPER_API_KEY=your_serper_api_key_here        # serper.dev → Dashboard (Google Search)
# APOLLO_API_KEY=your_apollo_api_key_here      # apollo.io → Settings → API Keys (50 req/day free)
# YOUTUBE_API_KEY=your_youtube_api_key_here
# BUILTWITH_API_KEY=your_builtwith_api_key_here

# === APP SETTINGS ===
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production

# === CORS (через запятую) ===
# Для VDS: указать домен фронтенда
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === FRONTEND ===
# Для VDS: https://your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# === CACHE ===
COMPANY_CACHE_TTL_DAYS=30

# === PIPELINE ===
# PIPELINE_TIMEOUT_SECONDS=300
# MAX_CONCURRENT_COLLECTORS=14
